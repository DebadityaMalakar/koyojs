{
  "name": "koyojs",
  "version": "0.1.1",
  "description": "Koyo JS — essential utilities",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./dist/index.bun.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./String": {
      "types": "./dist/String/index.d.ts",
      "import": "./dist/String/index.mjs",
      "require": "./dist/String/index.cjs"
    },
    "./Number": {
      "types": "./dist/Number/index.d.ts",
      "import": "./dist/Number/index.mjs",
      "require": "./dist/Number/index.cjs"
    }
  },
  "license": "MIT",
  "files": ["dist"],
  "scripts": {
    "build": "bun run scripts/build.ts && bun run types",
    "types": "tsc --project tsconfig.build.json",
    "dev": "bun --watch src/index.ts",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
